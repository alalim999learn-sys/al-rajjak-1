



 CREATE TABLE BISMILLAH_table (

    -- Basic Info

    id TEXT PRIMARY KEY,

    brand TEXT,

    title TEXT,

    type TEXT,

    status TEXT,

    description TEXT,

    

    -- Pricing

    original_price DECIMAL,

    current_price DECIMAL,

    currency TEXT DEFAULT 'EUR',

    discount_label TEXT,

    

    -- Service Info (Stored as JSONB for flexibility)

    service_info JSONB,

    

    -- Technical Details

    dimensions TEXT,

    color_primary TEXT,

    fabric_type TEXT,

    

    -- Media

    images TEXT[], -- Array of image strings

    

    -- Deep Specifications (Detailed info)

    material_info JSONB,

    frame_info JSONB,

    cushion_info JSONB,

    dimensions_detailed JSONB,

    warranty_info JSONB,

    delivery_info JSONB,

    

    -- Status & Stock

    colors_available JSONB,

    certifications JSONB,

    load_capacity JSONB,

    payment_info JSONB,

    

    -- System Fields

    created_at TIMESTAMP WITH TIME ZONE DEFAULT TIMEZONE('utc'::text, NOW())

); 

